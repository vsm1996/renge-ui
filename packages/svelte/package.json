{
  "name": "@renge-ui/svelte",
  "version": "1.1.0",
  "description": "Svelte stores and components for the Renge design system.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r src/components dist/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "design-system",
    "svelte",
    "stores",
    "golden-ratio"
  ],
  "author": "Vanessa Martin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vsm1996/renge-ui"
  },
  "packageManager": "pnpm@10.30.2",
  "dependencies": {
    "@renge-ui/tokens": "^2.6.1"
  },
  "peerDependencies": {
    "svelte": "^4.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^4.0.5",
    "@testing-library/user-event": "^14.5.1",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.1.0",
    "svelte": "^4.2.20",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
