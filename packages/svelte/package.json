{
  "name": "@renge-ui/svelte",
  "version": "1.0.0",
  "description": "Svelte stores and components for the Renge design system.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "design-system",
    "svelte",
    "stores",
    "golden-ratio"
  ],
  "author": "Vanessa Martin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vsm1996/renge-ui"
  },
  "packageManager": "pnpm@10.30.2",
  "dependencies": {
    "@renge-ui/tokens": "^2.4.0"
  },
  "peerDependencies": {
    "svelte": "^4.0.0"
  },
  "devDependencies": {
    "svelte": "^4.2.20",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
