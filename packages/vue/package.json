{
  "name": "@renge-ui/vue",
  "version": "1.0.1",
  "description": "Vue 3 composables and components for the Renge design system.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r src/components dist/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "design-system",
    "vue",
    "composables",
    "golden-ratio"
  ],
  "author": "Vanessa Martin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vsm1996/renge-ui"
  },
  "packageManager": "pnpm@10.30.2",
  "dependencies": {
    "@renge-ui/tokens": "^2.6.1"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/user-event": "^14.5.1",
    "@testing-library/vue": "^8.1.0",
    "@vitest/ui": "^1.6.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "vue": "^3.4.27"
  }
}
