{
  "name": "@renge-ui/tokens",
  "version": "1.0.3",
  "description": "Design tokens for the Renge design system — φ-based typography, Fibonacci spacing, OKLCH colors, natural motion.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "design-system",
    "tokens",
    "css-variables",
    "golden-ratio",
    "fibonacci"
  ],
  "author": "Vanessa Martin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vsm1996/renge-ui"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
